# =============================================================================
# Docker Compose environment for the Enterprise AutoML Platform.
# Copy to `.env` and set at least SECRET_KEY and the superuser credentials.
# =============================================================================

ENVIRONMENT=production

# REQUIRED — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-secret

# Database
POSTGRES_USER=automl
POSTGRES_PASSWORD=automl
POSTGRES_DB=automl

# Bootstrap superuser (seeded on first start-up)
FIRST_SUPERUSER_EMAIL=admin@automl.local
FIRST_SUPERUSER_PASSWORD=ChangeMe123!

# CORS — the frontend origin(s), comma-separated
BACKEND_CORS_ORIGINS=http://localhost:8080

# MLflow tracking
MLFLOW_ENABLED=true

# ---------------------------------------------------------------------------
# Service URLs after `docker compose up`:
#   Frontend  → http://localhost:8080
#   API docs  → http://localhost:8000/docs
#   MLflow    → http://localhost:5000
# ---------------------------------------------------------------------------
