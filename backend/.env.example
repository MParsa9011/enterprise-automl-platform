# =============================================================================
# Enterprise AutoML Platform — backend environment
# Copy to `.env` and adjust for your environment. NEVER commit a real `.env`.
# =============================================================================

# --- General ---
PROJECT_NAME="Enterprise AutoML Platform"
ENVIRONMENT=local            # local | development | staging | production | test
DEBUG=true
VERSION=1.0.0

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=20160
JWT_ALGORITHM=HS256
PASSWORD_MIN_LENGTH=8

# --- CORS (comma-separated) ---
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ALLOWED_HOSTS=*

# --- Database ---
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=automl
POSTGRES_PASSWORD=automl
POSTGRES_DB=automl
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# --- Redis / Celery ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# --- Rate limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120

# --- Storage / ML ---
STORAGE_ROOT=./storage
MAX_UPLOAD_SIZE_MB=512
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Pagination ---
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=true
